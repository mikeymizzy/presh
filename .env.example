# Required: OpenAI API key used by app/api/chat and app/api/upload
OPENAI_API_KEY=your_openai_api_key_here

# Required for ChatKit/Agent Builder integration
OPENAI_WORKFLOW_ID=wf_your_workflow_id_here

# Optional: fallback model when OPENAI_WORKFLOW_ID is not set
OPENAI_MODEL=gpt-4.1-mini

# Supabase configuration for submission storage
SUPABASE_URL=https://omxhddfxldlkoyokdemk.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: override submissions table name
SUPABASE_SUBMISSIONS_TABLE=submissions
